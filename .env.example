# ─────────────────────────────────────────────────────────────────
# MINDFULLY BRAND — Automation System
# .env.example → copy to .env and fill in
#
# CHANNELS:
#   channel_fitness     : Mindfully Fitness (Mon/Wed/Fri)
#   channel_ambiance    : Mindfully Ambiance (Tue/Thu)
#   channel_documentary : Mindfully Docs (Sat)
# ─────────────────────────────────────────────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Google
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json
# Sheet: https://docs.google.com/spreadsheets/d/1OoxhsKaWSPLKaIs0O4klzIjHdwZQoQ7fLidkFkNS2Kg
GOOGLE_SHEETS_ID=1OoxhsKaWSPLKaIs0O4klzIjHdwZQoQ7fLidkFkNS2Kg

# GitHub Backup
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=your_username/yt-otomasyon

# Sentry Error Tracking
SENTRY_DSN=your_sentry_dsn_here

# Encryption — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# Optional Cloud LLMs (leave empty → Ollama used by default)
GEMINI_API_KEY=
CLAUDE_API_KEY=
DEEPSEEK_API_KEY=

# Kit (ConvertKit) Email
KIT_API_KEY=
KIT_API_SECRET=

# Gumroad
GUMROAD_ACCESS_TOKEN=

# Pexels (visuals for videos)
PEXELS_API_KEY=

# ── Social Media Pipeline 1: Organic ─────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
TIKTOK_ACCESS_TOKEN=
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# ── Social Media Pipeline 2 + Shopify ────────────────────────────
# Shopify — configure when store is ready (Phase 2.5+)
# Admin API key — read-only scopes: read_products, read_inventory
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Printify (Phase 4)
PRINTIFY_API_KEY=

# ── YouTube OAuth ─────────────────────────────────────────────────
# Managed automatically via /add_channel Telegram command
# Stored encrypted in Sheets — do NOT add manually here
# CHANNEL_FITNESS_REFRESH_TOKEN=    ← auto-filled
# CHANNEL_AMBIANCE_REFRESH_TOKEN=   ← auto-filled
# CHANNEL_DOCS_REFRESH_TOKEN=       ← auto-filled

# ── Server Config ─────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=2
RAM_LIMIT_GB=3.5
LOG_LEVEL=INFO
N8N_PASSWORD=changeme_secure_password

# ── Freesound (telifsiz müzik — Ambiance kanalı için zorunlu) ────
# Ücretsiz API key: https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=your_freesound_api_key_here

# ── Webhook Güvenlik (HMAC imza doğrulama) ───────────────────────
# Gumroad: Settings → Advanced → Webhook secret
GUMROAD_WEBHOOK_SECRET=
# n8n → Python internal token (kendin belirle, n8n Variables'a ekle)
N8N_INTERNAL_TOKEN=your_random_secure_token_here
